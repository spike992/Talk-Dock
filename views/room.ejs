<!DOCTYPE html>
<html lang="en">
<head>
    <script>
        const ROOM_ID = "<%= roomId %>"
    </script>
    <script defer src="https://unpkg.com/peerjs@1.4.7/dist/peerjs.min.js"></script>
    <script src="/socket.io/socket.io.js" defer></script>
    <script src="../public/script.js" defer></script>
    <meta charset="UTF-8">
    <title>Chatroom</title>
    <style>
        body {
            background-color: #f8f8f8;
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: row;
            justify-content: flex-end;
            align-items: stretch;
            height: 100vh;
            margin: 0;
        }

        #message-container {
            max-width: 600px;
            padding: 20px;
            background-color: #ffffff;
            border-radius: 5px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
        }

        #messages {
            list-style-type: none;
            padding: 0;
            margin: 0;
        }

        #messages li {
            margin-bottom: 10px;
            overflow-wrap: break-word;
        }

        #messages li:last-child {
            margin-bottom: 0;
        }

        #form {
            display: flex;
            align-items: flex-end;
            margin-top: 10px;
        }

        #input {
            flex-grow: 1;
            padding: 5px;
            border: 1px solid #cccccc;
            border-radius: 3px;
            font-size: 14px;
        }

        #submit-btn {
            width: 60px;
            padding: 5px;
            border: none;
            background-color: #4CAF50;
            color: #ffffff;
            border-radius: 3px;
            font-size: 14px;
            cursor: pointer;
            margin-left: 10px;
        }

        #video-grid {
            flex: 1;
            display: grid;
            grid-template-columns: repeat(auto-fill, 300px);
            grid-auto-rows: 300px;
            gap: 20px;
            justify-content: flex-start;
            align-items: center;
            padding: 20px;
        }

        video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 5px;
        }
    </style>
</head>
<body>
    <div id="video-grid">
    </div>
    <div id="message-container">
        <ul id="messages"></ul>
        <form id="form">
            <input id="input" autocomplete="off" placeholder="Type your message" />
            <button id="submit-btn">Send</button>
        </form>
    </div>
</body>
</html>
