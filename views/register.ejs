<!doctype html>
<html lang="en">
  <head>
  	<title>Sign Up 09</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

	<link href="https://fonts.googleapis.com/css?family=Lato:300,400,700&display=swap" rel="stylesheet">

	<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
	
	<link rel="stylesheet" href="../public/register/css/style.css">

	</head>
	<body class="img" style="background-image: url(../public/register/images/bg.jpg);">
	<section class="ftco-section">
		<div class="container">
			<div class="row justify-content-center">
				<div class="col-md-6 text-center mb-5">
					<h2 class="heading-section">Sign Up #09</h2>
				</div>
			</div>
			<div class="row justify-content-center">
				<div class="col-md-7 col-lg-5">
					<div class="login-wrap">
		      	<h3 class="text-center mb-4">Create Your Account</h3>
						<form action="/register" method="post" class="signup-form" id="ob1">
		      		<div class="form-group mb-3">
		      			<label class="label" for="name">Full Name</label>
		      			<input type="text" class="form-control" placeholder="John Doe" name="username">
		      			<span class="icon fa fa-user-o"></span>
		      		</div>
		      		<div class="form-group mb-3">
		      			<label class="label" for="email" >Email Address</label>
		      			<input type="text" class="form-control" placeholder="johndoe@gmail.com" name="email">
		      			<span class="icon fa fa-paper-plane-o"></span>
		      		</div>
	            <div class="form-group mb-3">
	            	<label class="label" for="password">Password</label>
	              <input id="password" type="password" class="form-control" placeholder="Password" name="password">
	              <span toggle="#password" class="fa fa-fw fa-eye field-icon toggle-password"></span>
	              <span class="icon fa fa-lock"></span>
	            </div>
	            <div class="form-group mb-3">
	            	<label class="label" for="password">Password</label>
	              <input id="password-confirm" type="password" class="form-control" placeholder="Password">
	              <span toggle="#password-confirm" class="fa fa-fw fa-eye field-icon toggle-password"></span>
	              <span class="icon fa fa-lock"></span>
	            </div>
	            <div class="form-group">
	            	<button type="submit" class="form-control btn btn-primary submit px-3" onclick="dodajUporabnika()">Sign Up</button>
	            </div>
	          </form>
	          <p>I'm already a member! <a data-toggle="tab" href="#">Sign In</a></p>
	        </div>
				</div>
			</div>
		</div>
	</section>


	<script>
		function dodajUporabnika(){
			var username = document.ob1.ime.value;
			var gmail = document.ob1.mail.value;
			var password = document.ob1.geslo.value;

			var sql = `INSERT INTO users (ime, email, geslo) VALUES ('${username}', '${gmail}', '${password}')`;

			connection.query(sql, (err, result) => {
			if (err) throw err;
			console.log(`New user created with username ${username}`);
			});

		}
	</script>
	<script src="../public/register/js/jquery.min.js"></script>
  <script src="../public/register/js/popper.js"></script>
  <script src="../public/register/js/bootstrap.min.js"></script>
  <script src="../public/register/js/main.js"></script>

	</body>
</html>

